@page
@model LoginModel

@{
    ViewData["Title"] = "Login";
}

<!-- BOOTSTRAP -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body {
        background: #fffdf5;
    }

    /* CENTER */
    .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
    }

    /* CARD */
    .login-card {
        width: 100%;
        max-width: 400px;
        border-radius: 15px;
        overflow: hidden;
        background: #ffffff;
        box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        border-top: 5px solid #f4c430;
    }

    /* HEADER */
    .login-header {
        background: linear-gradient(135deg, #f4c430, #ffd95a);
        color: #333;
        padding: 25px;
    }

    /* ICON */
    .icon-circle {
        width: 55px;
        height: 55px;
        margin: auto;
        border-radius: 50%;
        background: rgba(255,255,255,0.6);
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 26px;
    }

    /* INPUT */
    .custom-input {
        border-radius: 10px;
        padding: 12px;
        border: 1px solid #ddd;
    }

    /* BUTTON */
    .login-btn {
        background: #f4c430;
        color: #000;
        border-radius: 10px;
        padding: 12px;
        font-weight: bold;
    }

        .login-btn:hover {
            background: #e0b020;
        }

    a {
        color: #c49b00;
    }

        a:hover {
            color: #a88400;
        }
</style>

<div class="login-container">
    <div class="login-card">

        <!-- HEADER -->
        <div class="login-header text-center pt-3 pb-2">

            <div class="mb-1">
                <img src="~/images/irp-logo.png" alt="IRPMS Logo" style="max-width: 240px; height: auto;" />
            </div>

            <p class="mb-0 mt-2" style="font-weight: 600; color: #444;">Access your account</p>
        </div>

        <!-- FORM -->
        <div class="p-4">
            <form method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- EMAIL -->
                <div class="mb-3">
                    <input asp-for="Input.Email"
                           class="form-control custom-input"
                           placeholder="Email address"
                           autocomplete="username" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <!-- PASSWORD -->
                <div class="mb-3">
                    <div class="input-group">
                        <input asp-for="Input.Password"
                               type="password"
                               class="form-control custom-input"
                               placeholder="Password"
                               autocomplete="current-password"
                               id="password-input" />
                        <button class="btn btn-outline-secondary" type="button" id="toggle-password" style="border-top-right-radius: 10px; border-bottom-right-radius: 10px; border: 1px solid #ddd; border-left: none;">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <!-- OPTIONS -->
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label class="form-check-label">Remember me</label>
                    </div>

                    <a asp-page="./ForgotPassword" class="small">
                        Forgot password?
                    </a>
                </div>

                <!-- BUTTON -->
                <button type="submit" class="btn login-btn w-100">
                    Sign in
                </button>

            </form>        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <!-- SweetAlert -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @if (TempData["Success"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: '🎉 Account Created!',
                text: '@TempData["Success"]',
                confirmButtonColor: '#f4c430',
                background: '#fff',
                timer: 2000,
                showConfirmButton: false
            });
        </script>
    }
    <script>
        document.getElementById('toggle-password').addEventListener('click', function (e) {
            const passwordInput = document.getElementById('password-input');
            const icon = this.querySelector('i');
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                passwordInput.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        });
    </script>
}
