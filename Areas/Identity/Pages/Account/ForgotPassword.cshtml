@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
}

<style>
    body {
        background: #fffdf5;
    }

    .auth-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
        padding: 20px;
    }

    .auth-card {
        width: 100%;
        max-width: 450px;
        border-radius: 20px;
        overflow: hidden;
        background: #ffffff;
        box-shadow: 0 12px 30px rgba(0,0,0,0.08);
        border-top: 6px solid #f4c430;
    }

    .auth-header {
        background: linear-gradient(135deg, #f4c430, #ffd95a);
        color: #333;
        padding: 30px;
        text-align: center;
    }

    .icon-circle {
        width: 60px;
        height: 60px;
        margin: 0 auto 15px;
        border-radius: 50%;
        background: rgba(255,255,255,0.6);
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 28px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

    .auth-header h4 {
        font-weight: 800;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .auth-header p {
        font-size: 0.9rem;
        opacity: 0.8;
        margin-top: 5px;
    }

    .form-label {
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #666;
        margin-bottom: 8px;
    }

    .custom-input {
        border-radius: 12px;
        padding: 12px 15px;
        border: 2px solid #f0f0f0;
        transition: all 0.2s;
    }

    .custom-input:focus {
        border-color: #f4c430;
        box-shadow: 0 0 0 4px rgba(244, 196, 48, 0.15);
        outline: none;
    }

    .btn-recover {
        background: #f4c430;
        color: #000;
        border: none;
        border-radius: 12px;
        padding: 14px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.2s;
    }

    .btn-recover:hover {
        background: #e0b020;
        transform: translateY(-2px);
    }
</style>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <div class="icon-circle">📩</div>
            <h4>Forgot Password</h4>
            <p>Enter your email to receive a recovery link</p>
        </div>

        <div class="p-4">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                <div class="mb-4">
                    <label asp-for="Input.Email" class="form-label">Email Address</label>
                    <input asp-for="Input.Email" class="form-control custom-input" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <button type="submit" class="w-100 btn btn-recover">Send Reset Link</button>

                <div class="text-center mt-3">
                    <a asp-page="./Login" class="small fw-semibold text-decoration-none" style="color: #c49b00;">
                        <i class="bi bi-arrow-left me-1"></i> Back to Login
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
