@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
}

<style>
    body {
        background: #fffdf5;
    }

    .auth-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
        padding: 20px;
    }

    .auth-card {
        width: 100%;
        max-width: 450px;
        border-radius: 20px;
        overflow: hidden;
        background: #ffffff;
        box-shadow: 0 12px 30px rgba(0,0,0,0.08);
        border-top: 6px solid #f4c430;
    }

    .auth-header {
        background: linear-gradient(135deg, #f4c430, #ffd95a);
        color: #333;
        padding: 30px;
        text-align: center;
    }

    .icon-circle {
        width: 60px;
        height: 60px;
        margin: 0 auto 15px;
        border-radius: 50%;
        background: rgba(255,255,255,0.6);
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 28px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

    .auth-header h4 {
        font-weight: 800;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .auth-header p {
        font-size: 0.9rem;
        opacity: 0.8;
        margin-top: 5px;
    }

    .form-label {
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #666;
        margin-bottom: 8px;
    }

    .custom-input {
        border-radius: 12px;
        padding: 12px 15px;
        border: 2px solid #f0f0f0;
        font-weight: 500;
        transition: all 0.2s;
    }

    .custom-input:focus {
        border-color: #f4c430;
        box-shadow: 0 0 0 4px rgba(244, 196, 48, 0.15);
        outline: none;
    }

    .btn-reset {
        background: #f4c430;
        color: #000;
        border: none;
        border-radius: 12px;
        padding: 14px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.2s;
        margin-top: 10px;
    }

    .btn-reset:hover {
        background: #e0b020;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(244, 196, 48, 0.3);
    }
</style>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <div class="icon-circle">🔑</div>
            <h4>Reset Password</h4>
            <p>Create a secure new password for your account</p>
        </div>

        <div class="p-4">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>
                <input asp-for="Input.Code" type="hidden" />

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label">Email Address</label>
                    <input asp-for="Input.Email" class="form-control custom-input" autocomplete="username" aria-required="true" placeholder="Enter your email" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label">New Password</label>
                    <div class="input-group">
                        <input asp-for="Input.Password" class="form-control custom-input" type="password" autocomplete="new-password" aria-required="true" placeholder="••••••••" id="password-input" />
                        <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('password-input', this)" style="border-top-right-radius: 12px; border-bottom-right-radius: 12px; border: 2px solid #f0f0f0; border-left: none;">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.ConfirmPassword" class="form-label">Confirm Password</label>
                    <div class="input-group">
                        <input asp-for="Input.ConfirmPassword" class="form-control custom-input" type="password" autocomplete="new-password" aria-required="true" placeholder="••••••••" id="confirm-password-input" />
                        <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('confirm-password-input', this)" style="border-top-right-radius: 12px; border-bottom-right-radius: 12px; border: 2px solid #f0f0f0; border-left: none;">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="w-100 btn btn-reset">Reset Password</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword(inputId, element) {
            const passwordInput = document.getElementById(inputId);
            const icon = element.querySelector('i');
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                passwordInput.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        }
    </script>
}
