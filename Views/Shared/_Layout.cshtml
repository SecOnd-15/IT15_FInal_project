@using Microsoft.AspNetCore.Identity
@using Latog_Final_project.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject Latog_Final_project.Services.IBranchService BranchService


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IRP System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

</head>

<body>

    <div class="d-flex w-100" style="min-height: 100vh; overflow-x: hidden; background-color: var(--premium-bg);">

        @if (SignInManager.IsSignedIn(User))
        {
            <!-- OVERLAY -->
            <div class="overlay" onclick="toggleSidebar()"></div>

            <!-- ✅ SIDEBAR -->
            <div class="sidebar d-none d-md-flex">
                <div class="sidebar-header mb-4 text-center">
                    <img src="~/images/irp-logo.png" alt="Logo" class="img-fluid rounded-4" style="max-height: 120px;">
                </div>

                <hr class="mb-4" />

                <ul class="nav flex-column">

                    <!-- SUPERADMIN -->
                    @if (User.IsInRole("SuperAdmin"))
                    {
                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")"
                               asp-controller="SuperAdmin" asp-action="Dashboard">
                                <i class="bi bi-speedometer2"></i> Dashboard
                            </a>
                        </li>

                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "SuperAdmin" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" && (ViewBag.Mode == "admin") ? "active" : "")"
                               asp-controller="SuperAdmin" asp-action="Index" asp-route-branchId="1" asp-route-mode="admin">
                                <i class="bi bi-person-lock"></i> Admin Users
                            </a>
                        </li>

                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "AuditLog" ? "active" : "")"
                               asp-controller="SuperAdmin" asp-action="AuditLog">
                                <i class="bi bi-shield-check"></i> Audit Log
                            </a>
                        </li>

                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Branches" ? "active" : "")"
                               asp-controller="SuperAdmin" asp-action="Branches">
                                <i class="bi bi-building-gear"></i> Manage Barangays
                            </a>
                        </li>

                    }

                    <!-- CHAIRMAN -->
                    @if (User.IsInRole("Chairman"))
                    {
                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Chairman" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                               asp-controller="Chairman" asp-action="Index">
                                <i class="bi bi-person-badge"></i> Dashboard
                            </a>
                        </li>

                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Chairman" && ViewContext.RouteData.Values["action"]?.ToString() == "ForApproval" ? "active" : "")"
                               asp-controller="Chairman" asp-action="ForApproval">
                                <i class="bi bi-check2-square"></i> For Approval
                            </a>
                        </li>

                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Chairman" && ViewContext.RouteData.Values["action"]?.ToString() == "RejectedCompleted" ? "active" : "")"
                               asp-controller="Chairman" asp-action="RejectedCompleted">
                                <i class="bi bi-x-circle"></i> Rejected / Done
                            </a>
                        </li>

                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Chairman" && ViewContext.RouteData.Values["action"]?.ToString() == "ArchivedList" ? "active" : "")"
                               asp-controller="Chairman" asp-action="ArchivedList">
                                <i class="bi bi-archive"></i> Archive
                            </a>
                        </li>

                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Chairman" && ViewContext.RouteData.Values["action"]?.ToString() == "Budgets" ? "active" : "")"
                               asp-controller="Chairman" asp-action="Budgets">
                                <i class="bi bi-wallet2"></i> Budget
                            </a>
                        </li>

                    }

                    <!-- TREASURER -->
                    @if (User.IsInRole("Treasurer"))
                    {
                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Treasurer" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                               asp-controller="Treasurer" asp-action="Index">
                                <i class="bi bi-speedometer2"></i> Dashboard
                            </a>
                        </li>

                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Treasurer" && (ViewContext.RouteData.Values["action"]?.ToString() == "Pending" || ViewContext.RouteData.Values["action"]?.ToString() == "PendingRequests") ? "active" : "")"
                               asp-controller="Treasurer" asp-action="PendingRequests">
                                <i class="bi bi-hourglass-split"></i> Pending
                            </a>
                        </li>

                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Treasurer" && ViewContext.RouteData.Values["action"]?.ToString() == "Approved" ? "active" : "")"
                               asp-controller="Treasurer" asp-action="Approved">
                                <i class="bi bi-check-circle"></i> Approved
                            </a>
                        </li>

                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Treasurer" && ViewContext.RouteData.Values["action"]?.ToString() == "PurchaseOrders" ? "active" : "")"
                               asp-controller="Treasurer" asp-action="PurchaseOrders">
                                <i class="bi bi-receipt"></i> Purchase Orders
                            </a>
                        </li>

                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Treasurer" && (ViewContext.RouteData.Values["action"]?.ToString() == "POReceipt" || ViewBag.ActiveMenu == "POReceipt") ? "active" : "")"
                               asp-controller="Treasurer" asp-action="POReceipt">
                                <i class="bi bi-file-earmark-text"></i> PO Receipts
                            </a>
                        </li>

                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Treasurer" && ViewContext.RouteData.Values["action"]?.ToString() == "Invoices" ? "active" : "")"
                               asp-controller="Treasurer" asp-action="Invoices">
                                <i class="bi bi-receipt-cutoff"></i> Invoices
                            </a>
                        </li>

                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Inventory" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                               asp-controller="Inventory" asp-action="Index">
                                <i class="bi bi-box-seam"></i> Inventory
                            </a>
                        </li>

                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Inventory" && ViewContext.RouteData.Values["action"]?.ToString() == "Transactions" ? "active" : "")"
                               asp-controller="Inventory" asp-action="Transactions">
                                <i class="bi bi-clock-history"></i> Stock Transactions
                            </a>
                        </li>

                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Inventory" && ViewContext.RouteData.Values["action"]?.ToString() == "ArchivedTransactions" ? "active" : "")"
                               asp-controller="Inventory" asp-action="ArchivedTransactions">
                                <i class="bi bi-archive"></i> Archived Transactions
                            </a>
                        </li>

                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Treasurer" && (ViewContext.RouteData.Values["action"]?.ToString() == "ArchivedList" || ViewBag.ActiveMenu == "Archive") ? "active" : "")"
                               asp-controller="Treasurer" asp-action="ArchivedList">
                                <i class="bi bi-archive"></i> Archive
                            </a>
                        </li>

                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Treasurer" && ViewContext.RouteData.Values["action"]?.ToString() == "Budgets" ? "active" : "")"
                               asp-controller="Treasurer" asp-action="Budgets">
                                <i class="bi bi-wallet2"></i> Budget
                            </a>
                        </li>

                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AccountSettings" ? "active" : "")"
                               asp-controller="AccountSettings" asp-action="ChangePassword">
                                <i class="bi bi-person-gear"></i> My Profile
                            </a>
                        </li>
                    }

                    <!-- REGISTER (Chairman Only) -->
                    @if (User.IsInRole("Chairman"))
                    {
                        <li class="mt-2"></li>
                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Account/Register" ? "active" : "")"
                               asp-area="Identity"
                               asp-page="/Account/Register">
                                <i class="bi bi-person-check"></i> Account Users
                            </a>
                        </li>
                    }

                    <!-- STAFF -->
                    @if (User.IsInRole("Staff"))
                    {
                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Staff" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                               asp-controller="Staff" asp-action="Index">
                                <i class="bi bi-list-ul"></i> My Requests
                            </a>
                        </li>

                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Staff" && ViewContext.RouteData.Values["action"]?.ToString() == "Create" ? "active" : "")"
                               asp-controller="Staff" asp-action="Create">
                                <i class="bi bi-plus-circle"></i> Add Request
                            </a>
                        </li>

                        <li>
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AccountSettings" ? "active" : "")"
                               asp-controller="AccountSettings" asp-action="ChangePassword">
                                <i class="bi bi-person-gear"></i> My Profile
                            </a>
                        </li>
                    }

                </ul>

                @{
                    var branchNow = await BranchService.GetCurrentBranchAsync();
                    var branchNameNow = branchNow?.BranchName ?? "Global / Super";

                }

                <!-- Footer / Logout -->
                <div class="mt-auto pt-4">
                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
                        <button type="submit" class="btn w-100 fw-800 border-0 py-2 shadow-sm d-flex align-items-center justify-content-center transition-all logout-btn" style="background-color: #dc3545; color: white; border-radius: 10px;">
                            <i class="bi bi-box-arrow-right me-2"></i> Logout
                        </button>
                    </form>
                </div>
            </div>
        }




        <!-- ✅ MAIN CONTENT AREA -->
        <main class="main-content d-flex flex-column @(SignInManager.IsSignedIn(User) ? "" : "ms-0")" id="main-content-wrapper">
             @if (SignInManager.IsSignedIn(User))
             {
                <!-- MOBILE NAV BAR (Visible only on smaller screens) -->
                <nav class="navbar navbar-expand bg-white shadow-sm mb-4 rounded-4 px-3 d-md-none">
                    <div class="container-fluid">
                         <span class="navbar-brand fw-800 text-primary" style="font-size: 1rem;">IRP SYSTEM</span>
                         <button class="btn btn-sm btn-light border" onclick="toggleSidebar()">
                            <i class="bi bi-list fs-4"></i>
                         </button>
                    </div>
                </nav>
             }

             <div class="flex-grow-1">
                @RenderBody()
             </div>

        </main>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- ✅ SWEET ALERT -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- ✅ GLOBAL POPUP -->
    <script>
        function initPopups() {
            var successMessage = '@TempData["Success"]';
            if (successMessage && successMessage !== '') {
                Swal.fire({
                    icon: 'success',
                    title: '🎉 Success!',
                    text: successMessage,
                    confirmButtonColor: '#28a745'
                });
            }

            var errorMessage = '@TempData["Error"]';
            if (errorMessage && errorMessage !== '') {
                Swal.fire({
                    icon: 'error',
                    title: 'Oops!',
                    text: errorMessage,
                    confirmButtonColor: '#dc3545'
                });
            }

            var warningMessage = '@TempData["Warning"]';
            if (warningMessage && warningMessage !== '') {
                Swal.fire({
                    icon: 'warning',
                    title: 'Email Notification',
                    text: warningMessage,
                    confirmButtonColor: '#f39c12'
                });
            }
        }
        
        document.addEventListener("DOMContentLoaded", initPopups);
        document.addEventListener("turbo:load", initPopups);
    </script>

    <script>
        function toggleSidebar() {
            const sidebar = document.querySelector('.sidebar');
            const overlay = document.querySelector('.overlay');
            if (sidebar) sidebar.classList.toggle('active');
            if (overlay) overlay.classList.toggle('active');
        }

        // ✅ GLOBAL AJAX PAGINATION
        // Using delegation to catch all clicks on pagination links within our target container
        document.addEventListener("click", function (e) {
            // Find the closest anchor tag
            const link = e.target.closest("a.page-link");
            if (!link) return;

            // Check if this link is inside an AJAX pagination container
            const container = link.closest("#ajax-pagination-container");
            if (!container) return;

            // Stop the browser from performing a full page refresh
            e.preventDefault();

            const url = link.getAttribute("href");
            if (!url || url === "#") return;

            // Show loading state
            container.style.opacity = "0.5";
            container.style.pointerEvents = "none";

            fetch(url, {
                headers: { "X-Requested-With": "XMLHttpRequest" }
            })
            .then(response => {
                if (!response.ok) throw new Error("Network response was not ok");
                return response.text();
            })
            .then(html => {
                // Update the container content
                container.innerHTML = html;
                
                // Restore interactivity
                container.style.opacity = "1";
                container.style.pointerEvents = "auto";
                
                // Update URL in browser without refresh
                window.history.pushState(null, "", url);
                
                // OPTIONAL: Smoothly stay near the table if the content height changed dramatically
                // We don't want to jump to the top of the page.
            })
            .catch(err => {
                console.error("Pagination error:", err);
                // Fallback: If AJAX fails, we could potentially force a refresh, 
                // but usually staying on current page with an error is better.
                container.style.opacity = "1";
                container.style.pointerEvents = "auto";
            });
        });

        // ✅ GLOBAL LIVE DASHBOARD COUNTER
        function updateDashboardStats() {
            fetch('/Home/GetDashboardStats')
                .then(response => {
                    if (!response.ok) return;
                    return response.json();
                })
                .then(data => {
                    if (!data) return;

                    // Shared/SuperAdmin/Chairman IDs
                    if (data.pendingRequests !== undefined) updateElement('live-pending-requests', data.pendingRequests);
                    if (data.approvedRequests !== undefined) updateElement('live-approved-requests', data.approvedRequests);
                    if (data.rejectedRequests !== undefined) updateElement('live-rejected-requests', data.rejectedRequests);
                    if (data.totalUsers !== undefined) updateElement('live-total-users', data.totalUsers);
                    if (data.totalAuditLogs !== undefined) updateElement('live-total-audit', data.totalAuditLogs);

                    // Chairman specific IDs
                    if (data.pendingApprovals !== undefined) updateElement('live-pending-approvals', data.pendingApprovals);
                    if (data.totalRequests !== undefined) updateElement('live-total-requests', data.totalRequests);
                    if (data.totalSpending !== undefined) updateElement('live-total-spending', data.totalSpending.toLocaleString('en-PH', { style: 'currency', currency: 'PHP' }));
                    if (data.paidInvoices !== undefined) updateElement('live-paid-invoices', data.paidInvoices);

                    // Treasurer specific IDs
                    if (data.pendingRequests !== undefined) updateElement('live-pending-requests', data.pendingRequests);
                    if (data.unpaidInvoices !== undefined) updateElement('live-unpaid-invoices', data.unpaidInvoices);
                    if (data.unpaidAmount !== undefined) updateElement('live-unpaid-amount', data.unpaidAmount.toLocaleString('en-PH', { style: 'currency', currency: 'PHP' }));
                    if (data.paidAmount !== undefined) updateElement('live-paid-amount', data.paidAmount.toLocaleString('en-PH', { style: 'currency', currency: 'PHP' }));
                    if (data.totalRevenue !== undefined) updateElement('live-total-revenue', data.totalRevenue.toLocaleString('en-PH', { style: 'currency', currency: 'PHP' }));

                    // Staff specific IDs
                    if (data.myPendingRequests !== undefined) updateElement('live-my-pending', data.myPendingRequests);
                    if (data.myTotalRequests !== undefined) updateElement('live-my-total', data.myTotalRequests);
                })
                .catch(err => console.error("Stats update error:", err));
        }

        function updateElement(id, value) {
            const el = document.getElementById(id);
            if (el && el.innerText != value) {
                el.innerText = value;
                // Subtle flash effect
                el.style.transition = '0.3s';
                el.style.color = '#f4c430'; 
                setTimeout(() => { el.style.color = ''; }, 500);
            }
        }

        let dashboardIntervalId = null;
        
        function initDashboard() {
            if (dashboardIntervalId) {
                clearInterval(dashboardIntervalId);
            }
            if (document.getElementById('is-dashboard-page')) {
                updateDashboardStats();
                dashboardIntervalId = setInterval(updateDashboardStats, 15000);
            }
        }

        // Run on initial load and turbo transitions
        document.addEventListener("DOMContentLoaded", initDashboard);
        document.addEventListener("turbo:load", initDashboard);
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <!-- ✅ GLOBAL AJAX FORM HANDLER -->
    <script>
        document.addEventListener('submit', async function(e) {
            if (!e.target.classList.contains('ajax-form')) return;
            
            e.preventDefault();
            const form = e.target;
            const btn = form.querySelector('button[type="submit"]');
            const originalBtnHtml = btn ? btn.innerHTML : '';
            
            if (btn) {
                btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Loading...';
                btn.disabled = true;
            }

            try {
                const url = new URL(form.action || window.location.href);
                const formData = new FormData(form);
                const searchParams = new URLSearchParams(formData);
                url.search = searchParams.toString();

                const response = await fetch(url, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                
                if (!response.ok) throw new Error("Server error");
                
                const html = await response.text();
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');
                
                const newContent = doc.getElementById('main-content-wrapper');
                const oldContent = document.getElementById('main-content-wrapper');
                
                if (newContent && oldContent) {
                    oldContent.innerHTML = newContent.innerHTML;
                    window.history.pushState(null, "", url);
                    
                    // Re-evaluate scripts in the new content
                    const newScripts = oldContent.querySelectorAll('script');
                    newScripts.forEach(script => {
                        const newScript = document.createElement('script');
                        if (script.src) newScript.src = script.src;
                        else newScript.textContent = script.textContent;
                        document.body.appendChild(newScript);
                        // Optional: remove after running to keep DOM clean
                        setTimeout(() => newScript.remove(), 100);
                    });
                }
            } catch (err) {
                console.error("AJAX form submission failed:", err);
                // Fallback to normal submission
                form.submit();
            } finally {
                if (btn) {
                    btn.innerHTML = originalBtnHtml;
                    btn.disabled = false;
                }
            }
        });
    </script>
</body>
</html>
