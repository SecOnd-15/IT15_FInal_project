@model Latog_Final_project.Models.InvoiceViewModel

@{
    ViewData["Title"] = "Invoices";
    var overdueCount = (int)(ViewBag.OverdueCount ?? 0);
}

<h2 class="mb-4 fw-bold"><i class="bi bi-receipt-cutoff"></i> Invoice Management</h2>

@if (overdueCount > 0)
{
    <div class="alert border-0 shadow-sm d-flex align-items-center mb-4" style="border-radius: 12px; background: linear-gradient(135deg, rgba(220,53,69,0.08), rgba(220,53,69,0.03));">
        <div class="bg-danger bg-gradient p-2 rounded-3 me-3 text-white">
            <i class="bi bi-exclamation-triangle-fill fs-5"></i>
        </div>
        <div>
            <strong class="text-danger">@overdueCount Overdue Invoice@(overdueCount > 1 ? "s" : "")</strong>
            <span class="text-muted ms-2 small">— Payment is past the due date. Please review and take action.</span>
        </div>
    </div>
}

<!-- Search Bar -->
<div class="mb-3">
    <form method="get" asp-action="Invoices" class="d-flex gap-2 align-items-center">
        <div class="input-group" style="max-width: 400px;">
            <span class="input-group-text bg-white border-end-0" style="border-radius: 10px 0 0 10px;">
                <i class="bi bi-search text-muted"></i>
            </span>
            <input type="text" name="search" value="@ViewBag.CurrentSearch" class="form-control border-start-0 shadow-none"
                   placeholder="Search by item, supplier, invoice #, or status..."
                   style="border-radius: 0 10px 10px 0;" />
        </div>
        <button type="submit" class="btn btn-dark btn-sm px-3 fw-bold" style="border-radius: 10px;">Search</button>
        @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch as string))
        {
            <a asp-action="Invoices" class="btn btn-outline-secondary btn-sm px-3" style="border-radius: 10px;">Clear</a>
        }
    </form>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div id="ajax-pagination-container">
            @await Html.PartialAsync("_InvoicesTable", Model)
        </div>
    </div>
</div>

<!-- 💰 PAYMENT MODAL -->
<div class="modal fade" id="paymentModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius: 15px; overflow: hidden;">
            <div style="height: 5px; background: linear-gradient(90deg, #198754, #20c997);"></div>
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-cash-coin me-2 text-success"></i>Record Payment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="MarkAsPaid" method="post" id="paymentForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="paymentInvoiceId" />
                <div class="modal-body">
                    <div class="mb-3 p-3 bg-light rounded-3">
                        <div class="row text-center">
                            <div class="col-6">
                                <small class="text-muted">Total Amount</small>
                                <div class="fw-bold text-dark fs-5" id="paymentTotalDisplay">₱0.00</div>
                            </div>
                            <div class="col-6">
                                <small class="text-muted">Balance Due</small>
                                <div class="fw-bold text-danger fs-5" id="paymentBalanceDisplay">₱0.00</div>
                            </div>
                        </div>
                    </div>
                    <label class="form-label fw-bold small text-uppercase text-muted">Payment Amount (₱)</label>
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-light border-0" style="border-radius: 10px 0 0 10px;">₱</span>
                        <input name="amountPaid" type="number" step="0.01" min="0.01" class="form-control bg-light border-0"
                               id="paymentAmountInput" placeholder="0.00" required
                               style="border-radius: 0 10px 10px 0; font-weight: 600;" />
                    </div>
                    <div class="form-check mt-3">
                        <input class="form-check-input" type="checkbox" id="payFullCheck">
                        <label class="form-check-label small text-muted" for="payFullCheck">Pay full balance</label>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success px-4 fw-bold shadow-sm">
                        <i class="bi bi-check-circle me-1"></i> Confirm Payment
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- 📎 ATTACHMENT UPLOAD MODAL -->
<div class="modal fade" id="attachmentModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius: 15px; overflow: hidden;">
            <div style="height: 5px; background: linear-gradient(90deg, #0d6efd, #6f42c1);"></div>
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-paperclip me-2 text-primary"></i>Upload Attachment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="UploadAttachment" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="attachmentInvoiceId" />
                <div class="modal-body">
                    <p class="text-muted small mb-3">Upload a scanned receipt or document (PDF, JPG, PNG — max 5MB).</p>
                    <input type="file" name="attachment" class="form-control" accept=".pdf,.jpg,.jpeg,.png" required />
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm">
                        <i class="bi bi-upload me-1"></i> Upload
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function openPaymentModal(invoiceId, totalAmount, amountPaid) {
        document.getElementById('paymentInvoiceId').value = invoiceId;
        var balance = totalAmount - amountPaid;
        document.getElementById('paymentTotalDisplay').innerText = '₱' + totalAmount.toLocaleString('en-PH', {minimumFractionDigits: 2});
        document.getElementById('paymentBalanceDisplay').innerText = '₱' + balance.toLocaleString('en-PH', {minimumFractionDigits: 2});
        document.getElementById('paymentAmountInput').max = balance;
        document.getElementById('paymentAmountInput').value = '';
        document.getElementById('payFullCheck').checked = false;

        var payFullCheck = document.getElementById('payFullCheck');
        payFullCheck.onchange = function() {
            if (this.checked) {
                document.getElementById('paymentAmountInput').value = balance.toFixed(2);
            } else {
                document.getElementById('paymentAmountInput').value = '';
            }
        };

        var modal = new bootstrap.Modal(document.getElementById('paymentModal'));
        modal.show();
    }

    function openAttachmentModal(invoiceId) {
        document.getElementById('attachmentInvoiceId').value = invoiceId;
        var modal = new bootstrap.Modal(document.getElementById('attachmentModal'));
        modal.show();
    }
</script>
}
