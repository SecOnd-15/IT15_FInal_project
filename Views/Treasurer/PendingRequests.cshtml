@model Latog_Final_project.Models.ResourceRequestViewModel

@{
    ViewData["Title"] = "Pending Resource Requests";
}

<style>
    .page-header {
        background: linear-gradient(135deg, #FFC107 0%, #ffca2c 100%);
        border-radius: 16px;
        padding: 24px 32px;
        color: #212529;
        margin-bottom: 28px;
        box-shadow: 0 4px 15px rgba(255, 193, 7, 0.2);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .page-header h2 {
        font-weight: 700;
        margin: 0;
        font-size: 1.5rem;
    }

    .table-container {
        background: white;
        border-radius: 12px;
        padding: 24px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.05);
    }

    .custom-table th {
        background-color: #f8f9fa;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
        color: #6c757d;
        border: none;
        padding: 15px;
    }

    .custom-table td {
        padding: 15px;
        vertical-align: middle;
        border-top: 1px solid #f1f1f1;
    }

    .badge-pending {
        background-color: #fff3cd;
        color: #856404;
        border: 1px solid #ffeeba;
        padding: 6px 12px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.75rem;
    }
</style>

<div class="container-fluid py-2">
    <div class="page-header">
        <div>
            <h2><i class="bi bi-layout-text-window-reverse me-2"></i>Resource Requests Dashboard</h2>
            <p class="mb-0 text-muted small">Manage and forward staff resource requests for Chairman approval.</p>
        </div>
    </div>

    <div class="table-container">
        <div id="ajax-pagination-container">
            @await Html.PartialAsync("_PendingRequestsTable", Model)
        </div>
    </div>
</div>
