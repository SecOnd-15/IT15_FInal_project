@model Latog_Final_project.Models.ResourceRequest

@{
    ViewData["Title"] = "Create Purchase Order";
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4">
        <div class="bg-success bg-gradient p-3 rounded-3 shadow-sm me-3 text-white">
            <i class="bi bi-cart-check fs-3"></i>
        </div>
        <div>
            <h2 class="mb-1 fw-bold text-dark">Create Purchase Order</h2>
            <p class="text-muted mb-0">Select a budget category and entering final costs to finalize the procurement.</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-xl-8 col-lg-10">
            <div class="card border-0 shadow-sm overflow-hidden" style="border-radius: 15px;">
                <div style="height: 6px; background: linear-gradient(90deg, #198754, #20c997);"></div>
                
                <div class="card-body p-4 p-md-5">
                    <form asp-action="CreatePO" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />

                        <div class="row g-4">
                            <!-- ITEM INFO (READ ONLY) -->
                            <div class="col-md-8">
                                <label class="form-label fw-bold text-uppercase small text-muted mb-2">Item Name</label>
                                <input class="form-control form-control-lg bg-light border-0" value="@Model.ItemName" readonly style="border-radius: 10px;" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold text-uppercase small text-muted mb-2">Quantity</label>
                                <input class="form-control form-control-lg bg-light border-0" value="@Model.Quantity" readonly style="border-radius: 10px;" />
                            </div>

                            <hr class="my-2 opacity-5" />

                            <!-- BUDGET CATEGORY -->
                            <div class="col-md-12">
                                <label class="form-label fw-bold text-uppercase small text-muted mb-2">
                                    <i class="bi bi-folder2-open me-1 text-success"></i> Select Budget Category
                                </label>
                                
                                @if (!string.IsNullOrEmpty(Model.Category))
                                {
                                    <select class="form-select form-select-lg bg-light border-0" disabled style="border-radius: 10px; font-size: 1rem;">
                                        <option value="@Model.Category" selected>@Model.Category</option>
                                    </select>
                                    <input type="hidden" name="Category" value="@Model.Category" />
                                    <small class="text-success fw-bold"><i class="bi bi-lock-fill me-1"></i> Locked to category approved by Chairman</small>
                                }
                                else
                                {
                                    <select name="Category" class="form-select form-select-lg bg-light border-0" required style="border-radius: 10px; font-size: 1rem;">
                                        <option value="">-- Choose Category to Deduct Funds --</option>
                                        @if (ViewBag.Categories != null)
                                        {
                                            foreach (var cat in (List<Latog_Final_project.Models.Budget>)ViewBag.Categories)
                                            {
                                                <option value="@cat.CategoryName">@cat.CategoryName</option>
                                            }
                                        }
                                    </select>
                                }
                                <div class="text-danger small mt-1">@Html.ValidationMessage("Category")</div>
                            </div>

                            <!-- SUPPLIER -->
                            <div class="col-md-7">
                                <label class="form-label fw-bold text-uppercase small text-muted mb-2">
                                    <i class="bi bi-building me-1 text-success"></i> Supplier / Store
                                </label>
                                <input name="Supplier" class="form-control form-control-lg bg-light border-0" placeholder="Enter supplier name..." required style="border-radius: 10px;" />
                            </div>

                            <!-- TOTAL AMOUNT -->
                            <div class="col-md-5">
                                <label class="form-label fw-bold text-uppercase small text-muted mb-2">
                                    <i class="bi bi-currency-dollar me-1 text-success"></i> Final Total Amount (₱)
                                </label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light border-0 text-muted" style="border-radius: 10px 0 0 10px;">₱</span>
                                    <input name="TotalAmount" type="number" step="0.01" class="form-control bg-light border-0" placeholder="0.00" required style="border-radius: 0 10px 10px 0; font-size: 1.1rem; font-weight: 600;" />
                                </div>
                            </div>

                            <!-- DUE DATE (optional) -->
                            <div class="col-md-5">
                                <label class="form-label fw-bold text-uppercase small text-muted mb-2">
                                    <i class="bi bi-calendar-event me-1 text-success"></i> Due Date (optional)
                                </label>
                                <input name="DueDate" type="date" class="form-control form-control-lg bg-light border-0"
                                       style="border-radius: 10px;" />
                                <small class="text-muted">Defaults to 30 days from today if left blank.</small>
                            </div>

                            <!-- NOTES (optional) -->
                            <div class="col-md-7">
                                <label class="form-label fw-bold text-uppercase small text-muted mb-2">
                                    <i class="bi bi-sticky me-1 text-success"></i> Notes (optional)
                                </label>
                                <textarea name="Notes" class="form-control bg-light border-0" rows="2"
                                          placeholder="Any remarks or special instructions..."
                                          style="border-radius: 10px;"></textarea>
                            </div>

                            <div class="col-12 mt-4 pt-2">
                                <div class="alert alert-info border-0 shadow-sm d-flex align-items-center" style="border-radius: 12px; background-color: rgba(13, 202, 240, 0.08);">
                                    <i class="bi bi-info-circle-fill fs-4 text-info me-3"></i>
                                    <div class="small">
                                        Clicking <b>"Finalize PO"</b> will automatically deduct the amount from the selected budget and generate an invoice.
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4 d-flex flex-column flex-sm-row gap-2 pt-2">
                            <button type="submit" class="btn btn-success px-4 py-2 shadow-sm fw-bold border-0 transition-transform" style="border-radius: 8px; background: linear-gradient(135deg, #198754, #157347);">
                                <i class="bi bi-check-circle-fill me-2"></i> FINALIZE & CREATE PO
                            </button>
                            <a asp-action="Approved" class="btn btn-light px-4 py-2 fw-bold text-muted border-0" style="border-radius: 8px;">
                                CANCEL
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control:focus, .form-select:focus {
        box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.2) !important;
        border-color: #198754 !important;
        background-color: #fff !important;
    }

    .transition-transform {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .transition-transform:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(25, 135, 84, 0.3) !important;
    }
</style>
