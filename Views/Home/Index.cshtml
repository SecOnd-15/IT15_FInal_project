@{
    ViewData["Title"] = "HomePage";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body {
        background: linear-gradient(135deg, #fffdf5, #fff3c4);
        font-family: 'Segoe UI', sans-serif;
    }

    .auth-wrapper {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .auth-card {
        max-width: 420px;
        width: 95%;
        padding: 40px;
        border-radius: 18px;
        background: #ffffff;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        text-align: center;
        border-top: 6px solid #f4c430;
    }

    .barangay-logo {
        width: 70px;
        margin-bottom: 15px;
    }

    .auth-title {
        font-weight: 700;
        color: #333;
        margin-bottom: 5px;
    }

    .auth-subtitle {
        font-size: 14px;
        color: #777;
        margin-bottom: 30px;
    }

    .auth-btn {
        border-radius: 10px;
        padding: 12px;
        font-weight: 600;
    }

    .auth-btn-primary {
        background-color: #f4c430;
        color: #000;
    }

        .auth-btn-primary:hover {
            background-color: #e0b020;
        }

    .auth-btn-outline {
        border: 2px solid #f4c430;
        color: #c49b00;
    }

        .auth-btn-outline:hover {
            background-color: #f4c430;
            color: #000;
        }

    .footer-note {
        margin-top: 25px;
        font-size: 13px;
        color: #888;
    }
</style>

@if (!User.Identity!.IsAuthenticated)
{
    <div class="auth-wrapper">

        <div class="auth-card">

            <!-- 🏛 LOGO -->
            <div class="mb-3">
                <img src="~/images/irp-logo.png" alt="IRPMS Logo" style="max-width: 300px; height: auto;" />
            </div>

            <!-- TITLE -->
            <p class="auth-subtitle fw-bold mt-2">Welcome to the IRPMS Portal</p>

            <!-- BUTTONS -->
            <div class="d-grid gap-3">

                <a asp-area="Identity"
                   asp-page="/Account/Login"
                   class="btn auth-btn auth-btn-primary">
                    🔐 Log In
                </a>

              

            </div>

            <!-- FOOTER -->
            <p class="footer-note">
                Welcome     
            </p>

        </div>

    </div>
}
