@model Latog_Final_project.Models.AccountRequestFilterViewModel

@{
    ViewData["Title"] = "Account Requests";
}

<style>
    .request-wrapper { max-width: 1000px; margin: 0 auto; padding: 20px; }
    .page-header { margin-bottom: 24px; }
    .page-header h2 { font-weight: 700; color: #2b2b2b; }
    
    .request-table { width: 100%; border-collapse: separate; border-spacing: 0; background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
    .request-table thead { background: #f4c430; }
    .request-table th { padding: 12px 15px; text-align: left; font-weight: 700; font-size: 0.85rem; text-transform: uppercase; }
    .request-table td { padding: 12px 15px; border-bottom: 1px solid #f1f1f1; font-size: 0.9rem; vertical-align: middle; }
    
    .btn-approve { background: #28a745; color: #fff; border: none; padding: 5px 12px; border-radius: 6px; font-weight: 600; font-size: 0.8rem; }
    .btn-reject { background: #dc3545; color: #fff; border: none; padding: 5px 12px; border-radius: 6px; font-weight: 600; font-size: 0.8rem; }
    .btn-approve:hover { background: #218838; }
    .btn-reject:hover { background: #c82333; }
    
    .empty-state { text-align: center; padding: 40px; color: #888; }

    /* BADGES */
    .badge { display: inline-block; padding: 4px 10px; border-radius: 12px; font-size: 0.75rem; font-weight: 600; }
    .b-pending { background: #fff3cd; color: #856404; }
    .b-approved { background: #d4edda; color: #155724; }
    .b-rejected { background: #f8d7da; color: #721c24; }
    .b-default { background: #eee; color: #666; }

    /* FILTERS */
    .filter-section { background: #fff; padding: 15px 20px; border-radius: 12px; margin-bottom: 20px; border: 1px solid #eee; display: flex; align-items: center; gap: 15px; }
    .filter-group label { font-size: 0.8rem; font-weight: 600; color: #666; margin-right: 8px; }
    .filter-group select { padding: 6px 12px; border-radius: 8px; border: 1px solid #ddd; font-size: 0.85rem; width: 150px; }

    /* PAGINATION */
    .pagination-wrapper { margin-top: 24px; display: flex; justify-content: space-between; align-items: center; background: #fff; padding: 12px 20px; border-radius: 12px; border: 1px solid #f0f0f0; }
    .pagination-info { font-size: 0.85rem; color: #666; }
    .pagination { display: flex; gap: 6px; list-style: none; padding: 0; margin: 0; }
    .page-link { 
        display: inline-block; padding: 6px 12px; min-width: 32px; text-align: center; border-radius: 8px; 
        border: 1px solid #ddd; color: #555; text-decoration: none; font-size: 0.85rem; font-weight: 600; 
    }
    .page-link:hover { background: #f4c430; border-color: #f4c430; color: #2b2b2b; }
    .page-item.active .page-link { background: #f4c430; border-color: #f4c430; color: #2b2b2b; }
    .page-item.disabled .page-link { background: #f9f9f9; color: #ccc; border-color: #eee; pointer-events: none; }
</style>

<div class="request-wrapper">
    <div class="page-header">
        <h2><i class="bi bi-person-plus me-2"></i> Account Requests</h2>
        <p class="text-muted">Manage users who have requested access to the system.</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- FILTERS -->
    <div class="filter-section">
        <form method="get" asp-action="Index" class="d-flex align-items-center gap-2">
            <div class="filter-group">
                <label>Status:</label>
                <select name="status" onchange="this.form.submit()">
                    <option value="">All Statuses</option>
                    <option value="Pending" selected="@(Model.StatusFilter == "Pending")">Pending</option>
                    <option value="Approved" selected="@(Model.StatusFilter == "Approved")">Approved</option>
                    <option value="Rejected" selected="@(Model.StatusFilter == "Rejected")">Rejected</option>
                </select>
            </div>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary" style="border-radius: 8px;">Reset</a>
        </form>
    </div>

    <!-- AJAX CONTAINER -->
    <div id="ajax-pagination-container">
        @await Html.PartialAsync("_AccountRequestTable", Model)
    </div>
</div>
