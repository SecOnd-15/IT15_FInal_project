@model Latog_Final_project.Models.Inventory

@{
    ViewData["Title"] = "Stock Adjustment";
}

<h2 class="mb-4 fw-bold"><i class="bi bi-wrench"></i> Stock Adjustment</h2>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">

                <div class="alert alert-info">
                    <strong>Item:</strong> @Model.ItemName<br />
                    <strong>Current Stock:</strong> @Model.Quantity
                </div>

                <form asp-action="StockAdjust" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">New Correct Quantity</label>
                        <input type="number"
                               name="newQuantity"
                               class="form-control"
                               placeholder="Enter the correct stock count"
                               min="0"
                               value="@Model.Quantity"
                               required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Reason for Adjustment</label>
                        <textarea name="reason"
                                  class="form-control"
                                  rows="3"
                                  placeholder="e.g. Physical count mismatch, Damaged items removed..."
                                  required></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-wrench"></i> Apply Adjustment
                        </button>

                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>
