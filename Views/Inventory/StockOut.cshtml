@model Latog_Final_project.Models.Inventory

@{
    ViewData["Title"] = "Stock-Out";
}

<h2 class="mb-4 fw-bold"><i class="bi bi-box-arrow-up"></i> Stock-Out</h2>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">

                <div class="alert alert-info">
                    <strong>Item:</strong> @Model.ItemName<br />
                    <strong>Current Stock:</strong> @Model.Quantity
                </div>

                <form asp-action="StockOut" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Quantity to Remove</label>
                        <input type="number"
                               name="quantity"
                               class="form-control"
                               placeholder="Enter quantity"
                               min="1"
                               max="@Model.Quantity"
                               required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Reason / Department</label>
                        <textarea name="reason"
                                  class="form-control"
                                  rows="3"
                                  placeholder="e.g. Issued to IT Department, Used for event setup..."
                                  required></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-box-arrow-up"></i> Process Stock-Out
                        </button>

                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>
