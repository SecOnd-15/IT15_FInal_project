@model Latog_Final_project.Models.InventoryTransactionViewModel

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Date</th>
                <th>Item</th>
                <th>Type</th>
                <th>Qty</th>
                <th>Previous Stock</th>
                <th>New Stock</th>
                <th>Reason</th>
                <th>Performed By</th>
                <th class="text-center" style="width: 100px;">Action</th>
            </tr>
        </thead>

        <tbody>
            @if (!Model.Transactions.Any())
            {
                <tr>
                    <td colspan="9" class="text-center text-muted py-4">
                        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                        No transactions recorded yet.
                    </td>
                </tr>
            }
            else
            {
                @foreach (var tx in Model.Transactions)
                {
                    <tr>
                        <td class="text-muted small">
                            @tx.TransactionDate.ToString("MM/dd/yyyy hh:mm tt")
                        </td>

                        <td class="fw-semibold">@tx.ItemName</td>

                        <!-- TYPE BADGE -->
                        <td>
                            @if (tx.TransactionType == "Stock-In")
                            {
                                <span class="fw-bold" style="color: #059669; font-size: 0.82rem;">Stock-In</span>
                            }
                            else if (tx.TransactionType == "Stock-Out")
                            {
                                <span class="fw-bold" style="color: #dc2626; font-size: 0.82rem;">Stock-Out</span>
                            }
                            else
                            {
                                <span class="fw-bold" style="color: #2563eb; font-size: 0.82rem;">Adjustment</span>
                            }
                        </td>

                        <!-- QUANTITY -->
                        <td>
                            @if (tx.TransactionType == "Stock-In")
                            {
                                <span class="text-success fw-bold">+@tx.Quantity</span>
                            }
                            else if (tx.TransactionType == "Stock-Out")
                            {
                                <span class="text-danger fw-bold">-@tx.Quantity</span>
                            }
                            else
                            {
                                @if (tx.Quantity >= 0)
                                {
                                    <span class="text-primary fw-bold">+@tx.Quantity</span>
                                }
                                else
                                {
                                    <span class="text-primary fw-bold">@tx.Quantity</span>
                                }
                            }
                        </td>

                        <!-- PREVIOUS → NEW -->
                        <td class="text-muted">@tx.PreviousStock</td>
                        <td class="fw-semibold">@tx.NewStock</td>

                        <td class="small">@(tx.Reason ?? "—")</td>

                        <td class="small text-muted">@tx.PerformedBy</td>

                        <!-- ARCHIVE ACTION -->
                        <td class="text-center">
                            <form asp-action="ArchiveTransaction" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@tx.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-warning px-2 fw-bold"
                                        onclick="return confirm('Archive this transaction?');"
                                        style="border-radius: 6px;">
                                    <i class="bi bi-archive"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- PAGINATION -->
@if (Model.TotalPages > 1)
{
    <div class="d-flex justify-content-between align-items-center mt-3 bg-white p-3 rounded shadow-sm border">
        <div class="text-muted small">
            Page <strong>@Model.PageNumber</strong> of <strong>@Model.TotalPages</strong>
        </div>
        
        <nav>
            <ul class="pagination pagination-sm mb-0">
                <!-- PREVIOUS -->
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" 
                       asp-action="Transactions" 
                       asp-route-page="@(Model.PageNumber - 1)">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>

                <!-- PAGE NUMBERS -->
                @{
                    int startPage = Math.Max(1, Model.PageNumber - 2);
                    int endPage = Math.Min(Model.TotalPages, startPage + 4);
                    if (endPage - startPage < 4) startPage = Math.Max(1, endPage - 4);
                }

                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link" 
                           asp-action="Transactions" 
                           asp-route-page="@i">
                            @i
                        </a>
                    </li>
                }

                <!-- NEXT -->
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" 
                       asp-action="Transactions" 
                       asp-route-page="@(Model.PageNumber + 1)">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
}
