@model Latog_Final_project.Models.ResourceRequest

@{
    ViewData["Title"] = "Create Request";
}

<div class="container-fluid py-2">
    <!-- HEADER -->
    <div class="d-flex align-items-center mb-4">
        <div class="bg-warning bg-gradient p-3 rounded-3 shadow-sm me-3">
            <i class="bi bi-plus-circle-fill fs-3 text-dark"></i>
        </div>
        <div>
            <h2 class="mb-1 fw-bold text-dark">New Resource Request</h2>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-xl-9 col-lg-11">
            <div class="card border-0 shadow-sm overflow-hidden" style="border-radius: 15px;">
                <!-- ACCENT STRIP -->
                <div style="height: 6px; background: linear-gradient(90deg, #FFC107, #FF8F00);"></div>

                <div class="card-body p-4 p-md-5">
                    
                    <!-- QUICK TIPS AT TOP -->
                    <div class="mb-5 p-3 rounded-4" style="background: rgba(33, 37, 41, 0.04); border: 1px dashed rgba(0,0,0,0.1);">
                        <div class="row align-items-center">
                            <div class="col-lg-3 border-end border-md-0 mb-2 mb-lg-0">
                                <h6 class="fw-bold text-dark mb-0 small"><i class="bi bi-lightbulb-fill text-warning me-2"></i>Quick Tips:</h6>
                            </div>
                            <div class="col-lg-9">
                                <div class="row g-2">
                                    <div class="col-md-4">
                                        <div class="d-flex align-items-start">
                                            <i class="bi bi-check-circle-fill text-success me-2 mt-1 small"></i>
                                            <span class="small text-muted" style="font-size: 0.85rem;">Use <b>specific</b> names.</span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="d-flex align-items-start">
                                            <i class="bi bi-check-circle-fill text-success me-2 mt-1 small"></i>
                                            <span class="small text-muted" style="font-size: 0.85rem;">Check <b>inventory</b>.</span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="d-flex align-items-start">
                                            <i class="bi bi-check-circle-fill text-success me-2 mt-1 small"></i>
                                            <span class="small text-muted" style="font-size: 0.85rem;">Provide <b>clear purpose</b>.</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <form asp-action="Create" method="post" id="requestForm">
                        @Html.AntiForgeryToken()

                        <div class="row g-4">
                            <!-- ITEM NAME -->
                            <div class="col-md-7">
                                <label class="form-label fw-bold text-uppercase small text-muted mb-2">
                                    <i class="bi bi-tag-fill me-1 text-warning"></i> Item Name
                                </label>
                                <div class="input-group input-group-lg custom-input-group">
                                    <input asp-for="ItemName"
                                           class="form-control border-end-0 bg-light"
                                           placeholder="What do you need? (e.g. Bond Paper)" 
                                           style="border-radius: 10px 0 0 10px; font-size: 1rem;"/>
                                    <span class="input-group-text bg-light border-start-0 text-muted" style="border-radius: 0 10px 10px 0;">
                                        <i class="bi bi-pencil small"></i>
                                    </span>
                                </div>
                                <span asp-validation-for="ItemName" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <!-- QUANTITY -->
                            <div class="col-md-5">
                                <label class="form-label fw-bold text-uppercase small text-muted mb-2">
                                    <i class="bi bi-stack me-1 text-warning"></i> Quantity
                                </label>
                                <div class="input-group input-group-lg custom-input-group">
                                    <input asp-for="Quantity"
                                           type="number"
                                           class="form-control border-end-0 bg-light"
                                           placeholder="0" 
                                           style="border-radius: 10px 0 0 10px; font-size: 1rem;"/>
                                    <span class="input-group-text bg-light border-start-0 text-muted" style="border-radius: 0 10px 10px 0;">
                                        <i class="bi bi-hash small"></i>
                                    </span>
                                </div>
                                <span asp-validation-for="Quantity" class="text-danger small mt-1 d-block"></span>
                            </div>


                            <!-- PURPOSE -->
                            <div class="col-12">
                                <label class="form-label fw-bold text-uppercase small text-muted mb-2">
                                    <i class="bi bi-chat-left-text-fill me-1 text-warning"></i> Purpose of Request
                                </label>
                                <textarea asp-for="Purpose"
                                          class="form-control bg-light"
                                          rows="3"
                                          placeholder="Explain why this resource is needed..."
                                          style="border-radius: 10px; font-size: 1rem;"></textarea>
                                <span asp-validation-for="Purpose" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="mt-4 d-flex flex-column flex-sm-row gap-2">
                            <button type="submit" class="btn btn-warning px-4 py-2 shadow-sm fw-bold border-0 transition-transform" style="border-radius: 8px; background: linear-gradient(135deg, #FFC107, #FFB300);">
                                <i class="bi bi-send-fill me-2"></i> SUBMIT REQUEST
                            </button>
                            <a asp-action="Index" class="btn btn-light px-4 py-2 fw-bold text-muted border-0" style="border-radius: 8px;">
                                CANCEL
                            </a>
                        </div>
                    </form>
                </div>
            </div>
            
            <p class="text-center text-muted small mt-4 opacity-50">SK Integrated Resource & Procurement Management System</p>
        </div>
    </div>
</div>
</div>

<style>
    .custom-input-group .form-control:focus {
        box-shadow: none;
        border-color: #FFC107;
        background-color: #fff !important;
    }
    
    .custom-input-group .form-control:focus + .input-group-text {
        border-color: #FFC107;
        background-color: #fff !important;
        color: #FFC107 !important;
    }

    textarea:focus {
        box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.25) !important;
        border-color: #FFC107 !important;
        background-color: #fff !important;
    }

    .transition-transform {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .transition-transform:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(255, 193, 7, 0.3) !important;
    }

    .transition-transform:active {
        transform: translateY(0);
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
