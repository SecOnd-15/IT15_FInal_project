@model Latog_Final_project.Models.StaffRequestsViewModel

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="bg-light">
            <tr>
                <th class="border-0">Item Name</th>
                <th class="border-0">Quantity</th>
                <th class="border-0">Purpose</th>
                <th class="border-0">Status</th>
                <th class="border-0 text-end">Request Date</th>
                <th class="border-0 text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Requests.Any())
            {
                <tr>
                    <td colspan="6" class="text-center py-5 text-muted">
                        <i class="bi bi-inbox fs-1 d-block mb-3 opacity-25"></i>
                        No resource requests found yet.
                    </td>
                </tr>
            }
            else
            {
                @foreach (var request in Model.Requests)
                {
                    <tr>
                        <td class="fw-bold">@request.ItemName</td>
                        <td>@request.Quantity</td>
                        <td>@request.Purpose</td>
                        <td>
                            @if (request.Status == "Pending" || request.Status == "Pending Treasurer Review")
                            {
                                <span class="fw-bold" style="color: #d97706; font-size: 0.82rem;">Pending Review</span>
                            }
                            else if (request.Status == "Approved")
                            {
                                <span class="fw-bold" style="color: #059669; font-size: 0.82rem;">Approved</span>
                            }
                            else if (request.Status == "ForChairman" || request.Status == "Pending Chairman Approval")
                            {
                                <span class="fw-bold" style="color: #2563eb; font-size: 0.82rem;">For Chairman</span>
                            }
                            else if (request.Status == "Rejected")
                            {
                                <span class="fw-bold" style="color: #dc2626; font-size: 0.82rem;">Rejected</span>
                            }
                            else if (request.Status == "ToReceive" || request.Status == "Partially Received")
                            {
                                <span class="fw-bold" style="color: #3b82f6; font-size: 0.82rem;">@request.Status</span>
                            }
                            else if (request.Status == "Completed")
                            {
                                <span class="fw-bold" style="color: #1e293b; font-size: 0.82rem;">Completed</span>
                            }
                            else
                            {
                                <span class="fw-bold text-muted" style="font-size: 0.82rem;">@request.Status</span>
                            }
                        </td>
                        <td class="text-end text-muted">@request.RequestDate.ToString("MMM dd, yyyy")</td>
                        <td class="text-center">
                            @if (request.Status == "Pending")
                            {
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Edit" asp-route-id="@request.Id" class="btn btn-outline-dark btn-sm rounded-pill px-3 shadow-sm scale-on-hover">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@request.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this request?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3 shadow-sm scale-on-hover">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </div>
                            }
                            else
                            {
                                <button class="btn btn-light btn-sm rounded-pill px-3" disabled title="Only pending requests can be modified">
                                    <i class="bi bi-lock-fill"></i> Locked
                                </button>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-4 border-top pt-3">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div class="text-muted small order-2 order-md-1">
                Showing <b>@((Model.PageNumber - 1) * Model.PageSize + 1)</b> to <b>@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalRecords))</b> of <b>@Model.TotalRecords</b> results
            </div>
            <ul class="pagination pagination-sm m-0 order-1 order-md-2">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link border-0 shadow-none rounded-start-pill px-3" href="@Url.Action("Index", "Staff", new { page = Model.PageNumber - 1 })">
                        <i class="bi bi-chevron-left me-1"></i> Previous
                    </a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link border-0 shadow-none px-3" href="@Url.Action("Index", "Staff", new { page = i })">@i</a>
                    </li>
                }
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link border-0 shadow-none rounded-end-pill px-3" href="@Url.Action("Index", "Staff", new { page = Model.PageNumber + 1 })">
                        Next <i class="bi bi-chevron-right ms-1"></i>
                    </a>
                </li>
            </ul>
        </div>
    </nav>
}

<style>
    .scale-on-hover:hover {
        transform: scale(1.05);
        transition: transform 0.2s ease;
    }
</style>
