@model List<Latog_Final_project.Models.ApplicationUser>

@{
    ViewData["Title"] = "User Management";
}

<div class="container-fluid px-4 py-3">
    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4 pt-2">
        <div>
            <h1 class="fw-800 mb-0" style="letter-spacing: -0.04em;">@(ViewBag.Mode == "admin" ? "System Administrators" : ViewBag.SelectedBranchName + " Personnel")</h1>
            <p class="text-muted fw-500 mb-0"><i class="bi bi-shield-lock me-1 text-warning"></i> Manage user access and security protocols</p>
        </div>
        <div class="d-flex gap-2">
            @if (ViewBag.Mode == "admin")
            {
                <a asp-action="AddAdmin" class="btn btn-warning rounded-pill px-4 fw-800 shadow-sm d-flex align-items-center text-dark" style="height: 48px; border: none;">
                    <i class="bi bi-person-plus-fill me-2"></i> Add New Admin
                </a>
            }
            else
            {
                <a asp-action="Branches" class="btn btn-light rounded-pill px-4 fw-800 shadow-sm border-0" style="height: 48px; background-color: white;">
                    <i class="bi bi-arrow-left me-2"></i> Back to Barangays
                </a>
            }
        </div>
    </div>

    <!-- 🔍 SEARCH / FILTER -->
    <form method="get">
        <input type="hidden" name="branchId" value="@ViewBag.SelectedBranchId" />
        @if (ViewBag.Mode == "admin")
        {
            <input type="hidden" name="mode" value="admin" />
        }
        
        <div class="filter-bar p-card shadow-sm border-0 mb-4" style="background-color: white;">
            <div class="filter-group">
                <label class="text-uppercase small fw-800 text-muted letter-spacing-05 mb-2 d-block">Identifier Search</label>
                <input type="text" name="search" value="@ViewBag.Search" class="form-control rounded-pill border-0 shadow-sm px-4" style="background-color: #f8fafc; height: 42px;" placeholder="Search by email or name..." />
            </div>

            @if (ViewBag.Mode != "admin")
            {
                <div class="filter-group">
                    <label class="text-uppercase small fw-800 text-muted letter-spacing-05 mb-2 d-block">Structural Position</label>
                    <select name="role" class="form-select rounded-pill border-0 shadow-sm px-4" style="background-color: #f8fafc; height: 42px;">
                        <option value="">All Positions</option>
                        <option value="Chairman" selected="@(ViewBag.Role == "Chairman")">Chairman</option>
                        <option value="Secretary" selected="@(ViewBag.Role == "Secretary")">Secretary</option>
                        <option value="Treasurer" selected="@(ViewBag.Role == "Treasurer")">Treasurer</option>
                    </select>
                </div>
            }

            <div class="d-flex gap-2 align-items-end">
                <button type="submit" class="btn btn-warning rounded-pill px-4 fw-800 shadow-sm text-dark h-100" style="background-color: #facc15; border: none; min-height: 42px;">
                    <i class="bi bi-search me-2"></i> Search
                </button>
                <a asp-action="Index" asp-route-branchId="@ViewBag.SelectedBranchId" asp-route-mode="@ViewBag.Mode" class="btn btn-light rounded-circle shadow-sm border-0 d-flex align-items-center justify-content-center" style="width: 42px; height: 42px; background-color: white;">
                    <i class="bi bi-arrow-counterclockwise"></i>
                </a>
            </div>
        </div>
    </form>

    <!-- 📋 USER TABLE -->
    <div class="p-table-container mt-4">
        <table class="p-table">
            <thead>
                <tr>
                    <th>User Identity & Security</th>
                    @if (ViewBag.SelectedBranchId != null)
                    {
                        <th>Authorized Role</th>
                    }
                    <th class="text-center">Operations</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="3" class="text-center py-5 text-muted">
                            <i class="bi bi-person-x fs-1 d-block mb-2"></i>
                            <span class="fw-600">No personnel found for this selection.</span>
                        </td>
                    </tr>
                }
                @foreach (var user in Model)
                {
                    string roleName = ViewBag.UserRoles[user.Id];
                    var roleBadgeClass = roleName switch
                    {
                        "SuperAdmin" => "p-badge-warning",
                        "Chairman" => "p-badge-info",
                        "Treasurer" => "bg-soft-gold text-warning",
                        _ => "p-badge-secondary"
                    };

                    bool isDeactivated = user.LockoutEnd.HasValue && user.LockoutEnd > DateTimeOffset.Now;

                    <tr style="@(isDeactivated ? "opacity: 0.6; background-color: rgba(241, 245, 249, 0.5);" : "")">
                        <td>
                            <div class="d-flex align-items-center">
                                <div class=" rounded-circle bg-light d-flex align-items-center justify-content-center me-3" style="width: 42px; height: 42px;">
                                    <i class="bi bi-person text-secondary"></i>
                                </div>
                                <div>
                                    <div class="fw-800 @(isDeactivated ? "text-muted" : "text-dark")">
                                        @user.FullName
                                        @if (isDeactivated)
                                        {
                                            <span class="ms-2 badge rounded-pill bg-secondary tiny text-uppercase" style="font-size: 0.6rem;">Archived</span>
                                        }
                                    </div>
                                    <div class="text-muted small">@user.Email</div>
                                </div>
                            </div>
                        </td>
                        @if (ViewBag.SelectedBranchId != null)
                        {
                            <td>
                                <span class="fw-800 text-uppercase @(roleName == "SuperAdmin" ? "text-warning" : roleName == "Chairman" ? "text-info" : roleName == "Treasurer" ? "text-warning" : "text-secondary")" style="font-size: 0.8rem; letter-spacing: 0.05em;">
                                    @roleName
                                </span>
                            </td>
                        }
                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-2">
                                <a asp-action="ResetPassword" asp-route-userId="@user.Id" asp-route-mode="@ViewBag.Mode" class="btn btn-light btn-sm fw-800 rounded-pill px-3 border-0 shadow-sm" style="background-color: white; color: #f59e0b;">
                                    <i class="bi bi-key me-1"></i> Security
                                </a>
                                <form asp-action="ToggleUserStatus" method="post" class="m-0 toggle-user-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <input type="hidden" name="mode" value="@ViewBag.Mode" />
                                    @if (isDeactivated)
                                    {
                                        <button type="button" class="btn btn-link btn-sm fw-800 text-decoration-none toggle-user-btn text-success" data-action="reactivate" data-name="@user.FullName">
                                            <i class="bi bi-person-check me-1"></i> Reactivate
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-link btn-sm fw-800 text-decoration-none toggle-user-btn text-danger" data-action="archive" data-name="@user.FullName">
                                            <i class="bi bi-person-x me-1"></i> Archive
                                        </button>
                                    }
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.toggle-user-btn').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var action = btn.getAttribute('data-action');
                    var name = btn.getAttribute('data-name') || 'this user';
                    var isArchive = action === 'archive';

                    Swal.fire({
                        title: isArchive ? 'Archive User?' : 'Reactivate User?',
                        text: 'Are you sure you want to ' + action + ' ' + name + '?',
                        icon: isArchive ? 'warning' : 'question',
                        showCancelButton: true,
                        confirmButtonColor: isArchive ? '#dc3545' : '#10b981',
                        cancelButtonColor: '#64748b',
                        confirmButtonText: isArchive ? 'Yes, Archive' : 'Yes, Reactivate',
                        cancelButtonText: 'Cancel',
                        reverseButtons: true
                    }).then(function (result) {
                        if (result.isConfirmed) {
                            btn.closest('form').submit();
                        }
                    });
                });
            });
        });
    </script>
}
