@model Latog_Final_project.Models.Branch

@{
    ViewData["Title"] = "Edit Barangay Details";
}

<style>
    .edit-card-wrapper {
        min-height: 80vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
    }

    .edit-card {
        width: 100%;
        max-width: 650px;
        background: #ffffff;
        border-radius: 24px;
        padding: 45px 50px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.05);
        border: none;
    }

    .edit-card h2 {
        font-size: 2.2rem;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 35px;
        display: flex;
        align-items: center;
        letter-spacing: -0.03em;
    }

    .edit-card .form-label {
        font-weight: 700;
        font-size: 0.95rem;
        color: #0f172a;
        margin-bottom: 8px;
    }

    .edit-card .form-control {
        border-radius: 8px;
        padding: 12px 16px;
        border: 1px solid #cbd5e1;
        font-size: 1rem;
        color: #334155;
        background-color: #ffffff;
        transition: all 0.2s;
    }

    .edit-card .form-control:focus {
        border-color: #f4c430;
        box-shadow: 0 0 0 3px rgba(244, 196, 48, 0.15);
        outline: none;
    }

    .edit-card .btn-cancel {
        border: 1px solid #cbd5e1;
        background-color: #ffffff;
        color: #64748b;
        border-radius: 8px;
        padding: 10px 24px;
        font-weight: 600;
        transition: all 0.2s;
    }

    .edit-card .btn-cancel:hover {
        background-color: #f8fafc;
        color: #334155;
        border-color: #94a3b8;
    }

    .edit-card .btn-submit {
        background-color: #f4c430;
        color: #0f172a;
        border-radius: 8px;
        padding: 10px 24px;
        font-weight: 700;
        border: none;
        transition: all 0.2s;
    }

    .edit-card .btn-submit:hover {
        background-color: #e0b020;
    }
</style>

<div class="edit-card-wrapper">
    <div class="edit-card shadow-sm">
        <h2>
            <i class="bi bi-pencil text-warning me-3" style="font-size: 2.2rem; color: #f4c430 !important;"></i>
            Edit Barangay Details
        </h2>

        <form asp-action="EditBranch" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-4">
                <label asp-for="BranchName" class="form-label">Barangay Name</label>
                <input asp-for="BranchName" class="form-control" placeholder="Enter barangay name" required />
                <span asp-validation-for="BranchName" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Location" class="form-label">Location / Address</label>
                <input asp-for="Location" class="form-control" placeholder="Enter location/address" />
                <span asp-validation-for="Location" class="text-danger small"></span>
            </div>

            <div class="mb-5">
                <label asp-for="ContactNumber" class="form-label">Contact Number</label>
                <input asp-for="ContactNumber" class="form-control" placeholder="Enter contact number" />
                <span asp-validation-for="ContactNumber" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center">
                <a asp-action="Branches" class="btn btn-cancel">Cancel</a>
                <button type="submit" class="btn btn-submit">Update Barangay</button>
            </div>
        </form>
    </div>
</div>
