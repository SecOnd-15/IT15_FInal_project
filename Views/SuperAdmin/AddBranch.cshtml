@model Latog_Final_project.Models.CreateBarangayViewModel

@{
    ViewData["Title"] = "Add Barangay";
}

<div class="container-fluid px-4 py-3">
    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4 pt-2">
        <div>
            <h1 class="fw-800 mb-0" style="letter-spacing: -0.04em;">Add Barangay</h1>
            <p class="text-muted fw-500 mb-0"><i class="bi bi-geo-alt me-1 text-warning"></i> Configure new Barangay administrative unit</p>
        </div>
        <div>
            <a asp-action="Branches" class="btn btn-outline-secondary rounded-pill px-4 fw-800 border-0 bg-light">
                <i class="bi bi-arrow-left me-1"></i> Return to Network
            </a>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="p-card" style="border-top: 6px solid #facc15; border-radius: 18px;">
                <form asp-action="AddBranch" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <h5 class="mb-4 text-primary fw-800" style="letter-spacing: -0.02em;">Structural Configuration</h5>
                    <div class="row g-3 mb-4">
                        <div class="col-md-12">
                            <label asp-for="BranchName" class="form-label small fw-800 text-uppercase tracking-wider text-muted">Barangay Designation</label>
                            <input asp-for="BranchName" class="form-control form-control-lg border-2 rounded-3" placeholder="e.g. Barangay 22-C" required />
                            <span asp-validation-for="BranchName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Location" class="form-label small fw-800 text-uppercase tracking-wider text-muted">Geographic Coordinates/Address</label>
                            <input asp-for="Location" class="form-control form-control-lg border-2 rounded-3" placeholder="e.g. Davao City Core" />
                            <span asp-validation-for="Location" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ContactNumber" class="form-label small fw-800 text-uppercase tracking-wider text-muted">Communication Channel</label>
                            <input asp-for="ContactNumber" class="form-control form-control-lg border-2 rounded-3" placeholder="e.g. 0912-345-6789" />
                            <span asp-validation-for="ContactNumber" class="text-danger"></span>
                        </div>
                    </div>

                    <h5 class="mb-4 text-primary fw-800 pt-3" style="letter-spacing: -0.02em;">Command Assignment (Chairman)</h5>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label small fw-800 text-uppercase tracking-wider text-muted">Chairman Email</label>
                        <input asp-for="Email" class="form-control form-control-lg border-2 rounded-3" type="email" placeholder="e.g. chairman@irp-system.com" required />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Password" class="form-label small fw-800 text-uppercase tracking-wider text-muted">Password</label>
                            <input asp-for="Password" class="form-control form-control-lg border-2 rounded-3" type="password" required />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ConfirmPassword" class="form-label small fw-800 text-uppercase tracking-wider text-muted">Confirm Password</label>
                            <input asp-for="ConfirmPassword" class="form-control form-control-lg border-2 rounded-3" type="password" required />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="pt-4 text-end">
                        <button type="submit" class="btn btn-warning rounded-pill px-5 fw-800 shadow-sm text-dark h-100" style="background-color: #facc15; border: none; min-height: 48px;">
                            <i class="bi bi-check2-circle me-2"></i> Create Barangay
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
