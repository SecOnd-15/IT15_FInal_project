@model Latog_Final_project.Models.AuditLogFilterViewModel

<div class="p-table-container">
    <table class="p-table">
        <thead>
            <tr>
                <th>User Identity</th>
                <th>Action</th>
                <th>Module</th>
                <th>Entity Reference</th>
                <th>Timestamp</th>
                <th>Activity Details</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Logs.Any())
            {
                <tr>
                    <td colspan="6" class="text-center py-5 text-muted">
                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                        <span class="fw-600">No matching audit logs found.</span>
                    </td>
                </tr>
            }
            else
            {
                foreach (var log in Model.Logs)
                {
                    var userEmail = Model.Users.FirstOrDefault(u => u.Id == log.UserId)?.Email ?? "Unknown";
                    var badgeClass = log.Action.ToLower() switch
                    {
                        "create" or "add" => "p-badge-success",
                        "edit" or "update" or "modify" => "p-badge-warning",
                        "delete" or "remove" or "deactivate" => "p-badge-danger",
                        "approve" or "activate" => "p-badge-info",
                        _ => "p-badge-secondary"
                    };

                    <tr>
                        <td style="max-width: 180px;">
                            <div class="fw-700 text-primary truncate">@userEmail</div>
                            <div class="text-muted" style="font-size: 0.7rem;">ID: @log.UserId</div>
                        </td>
                        <td>
                            <span class="p-badge @badgeClass">@log.Action</span>
                        </td>
                        <td>
                            <span class="p-badge p-badge-secondary" style="background: rgba(0,0,0,0.05);">@log.Module</span>
                        </td>
                        <td class="fw-600 text-muted" style="font-size: 0.8rem;">#@log.EntityId</td>
                        <td>
                            <div class="fw-600">@log.Timestamp.ToString("MMM dd, yyyy")</div>
                            <div class="text-muted" style="font-size: 0.75rem;">@log.Timestamp.ToString("hh:mm tt")</div>
                        </td>
                        <td>
                            <div class="text-muted" style="font-size: 0.825rem; line-height: 1.4; max-width: 350px;">@log.Details</div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@if (Model.TotalPages > 1)
{
    <div class="d-flex justify-content-between align-items-center mt-4 p-card py-3">
        <div class="text-muted fw-500" style="font-size: 0.875rem;">
            Showing Page <strong>@Model.PageNumber</strong> of <strong>@Model.TotalPages</strong>
        </div>

        <nav>
            <ul class="pagination mb-0 gap-2">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="btn btn-outline-secondary btn-sm rounded-pill px-3" 
                       asp-action="AuditLog" 
                       asp-route-page="@(Model.PageNumber - 1)"
                       asp-route-roleFilter="@Model.Role"
                       asp-route-actionFilter="@Model.Action">
                        <i class="bi bi-chevron-left me-1"></i> Prev
                    </a>
                </li>

                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="btn btn-outline-secondary btn-sm rounded-pill px-3" 
                       asp-action="AuditLog" 
                       asp-route-page="@(Model.PageNumber + 1)"
                       asp-route-roleFilter="@Model.Role"
                       asp-route-actionFilter="@Model.Action">
                        Next <i class="bi bi-chevron-right ms-1"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
}
