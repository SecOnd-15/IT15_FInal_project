@model Latog_Final_project.Models.AddAdminViewModel

@{
    ViewData["Title"] = "Add New Admin";
}

<div class="container-fluid px-4 py-3">
    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4 pt-2">
        <div>
            <h1 class="fw-800 mb-0" style="letter-spacing: -0.04em;">Add New Admin</h1>
            <p class="text-muted fw-500 mb-0"><i class="bi bi-shield-lock me-1 text-warning"></i> Deploy new system administrator credentials</p>
        </div>
        <div>
            <a asp-action="Index" asp-route-branchId="1" asp-route-mode="admin" class="btn btn-outline-secondary rounded-pill px-4 fw-800 border-0 bg-light">
                <i class="bi bi-arrow-left me-1"></i> Return to Registry
            </a>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="p-card" style="border-top: 6px solid #facc15; border-radius: 18px;">
                <h5 class="mb-4 text-primary fw-800" style="letter-spacing: -0.02em;">Credential Specification</h5>
                <hr class="mb-4 opacity-10" />

                <form asp-action="AddAdmin" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label small fw-800 text-uppercase tracking-wider text-muted">Full Name</label>
                        <input asp-for="FullName" class="form-control form-control-lg border-2 rounded-3" placeholder="e.g. Juan Dela Cruz" required />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label small fw-800 text-uppercase tracking-wider text-muted">Email Address</label>
                        <input asp-for="Email" class="form-control form-control-lg border-2 rounded-3" type="email" placeholder="e.g. admin@irp-system.com" required />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Password" class="form-label small fw-800 text-uppercase tracking-wider text-muted">Password</label>
                            <input asp-for="Password" class="form-control form-control-lg border-2 rounded-3" type="password" required />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ConfirmPassword" class="form-label small fw-800 text-uppercase tracking-wider text-muted">Confirm Password</label>
                            <input asp-for="ConfirmPassword" class="form-control form-control-lg border-2 rounded-3" type="password" required />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="pt-3 text-end">
                        <button type="submit" class="btn btn-warning rounded-pill px-5 fw-800 shadow-sm text-dark h-100" style="background-color: #facc15; border: none; min-height: 48px;">
                            <i class="bi bi-person-plus-fill me-2"></i> Create Account
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
