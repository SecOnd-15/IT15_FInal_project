@model Latog_Final_project.Models.AuditLogFilterViewModel

@{
    ViewData["Title"] = "Audit Log";
}

<div class="container-fluid px-4 py-3">
    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4 pt-2">
        <div>
            <h1 class="fw-800 mb-0" style="letter-spacing: -0.04em;">Audit System</h1>
            <p class="text-muted fw-500 mb-0"><i class="bi bi-shield-check me-1"></i> Full System Integrity Logs</p>
        </div>
        <div class="result-count">
            <span class="p-badge p-badge-secondary px-3 py-2 fw-800">TOTAL LOG ENTRIES: @Model.TotalRecords</span>
        </div>
    </div>

    <!-- FILTER BAR -->
    <form method="get" asp-controller="SuperAdmin" asp-action="AuditLog">
        <div class="filter-bar p-card">
            <div class="filter-group">
                <label>User Role</label>
                <select name="roleFilter">
                    <option value="">All Roles</option>
                    @foreach (var r in Model.Roles)
                    {
                        <option value="@r" selected="@(Model.Role == r)">@r</option>
                    }
                </select>
            </div>
            <div class="filter-group">
                <label>Action Type</label>
                <select name="actionFilter">
                    <option value="">All Actions</option>
                    @foreach (var a in Model.Actions)
                    {
                        <option value="@a" selected="@(Model.Action == a)">@a</option>
                    }
                </select>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn-premium"><i class="bi bi-funnel me-2"></i> Filter</button>
                <a asp-controller="SuperAdmin" asp-action="AuditLog" class="btn btn-outline-secondary rounded-pill px-3 d-flex align-items-center justify-content-center" style="height: 42px;">
                    <i class="bi bi-arrow-counterclockwise"></i>
                </a>
            </div>
        </div>
    </form>

    <!-- AJAX CONTAINER -->
    <div id="ajax-pagination-container" class="mt-4">
        @await Html.PartialAsync("_AuditLogTable", Model)
    </div>
</div>
