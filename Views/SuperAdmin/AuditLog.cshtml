@model Latog_Final_project.Models.AuditLogFilterViewModel

@{
    ViewData["Title"] = "Audit Log";
}

<style>
    .audit-wrapper { max-width: 1200px; margin: 0 auto; padding: 20px; }

    .page-header { margin-bottom: 24px; }
    .page-header h2 { font-weight: 700; color: #2b2b2b; margin-bottom: 4px; }
    .page-header p { color: #888; margin: 0; }

    /* FILTER BAR */
    .filter-bar {
        background: #fff;
        border: 2px solid #f4c430;
        border-radius: 12px;
        padding: 16px 20px;
        margin-bottom: 20px;
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        align-items: end;
    }

    .filter-bar .filter-group { flex: 1; min-width: 140px; }
    .filter-bar label { font-size: 0.75rem; font-weight: 600; color: #666; display: block; margin-bottom: 3px; }
    .filter-bar select { width: 100%; padding: 6px 10px; border: 1px solid #ddd; border-radius: 8px; font-size: 0.85rem; }
    .filter-bar select:focus { outline: none; border-color: #f4c430; box-shadow: 0 0 0 2px rgba(244,196,48,0.2); }

    .btn-apply { background: #f4c430; color: #2b2b2b; font-weight: 600; border: none; border-radius: 8px; padding: 8px 20px; cursor: pointer; }
    .btn-apply:hover { background: #e0b400; }
    .btn-reset { background: #f1f1f1; color: #555; font-weight: 600; border: none; border-radius: 8px; padding: 8px 14px; cursor: pointer; text-decoration: none; }
    .btn-reset:hover { background: #e0e0e0; color: #333; }

    /* RESULT COUNT */
    .result-count { font-size: 0.85rem; color: #888; margin-bottom: 10px; }
    .result-count strong { color: #2b2b2b; }

    /* TABLE */
    .log-table { width: 100%; border-collapse: separate; border-spacing: 0; background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 1px 8px rgba(0,0,0,0.06); }
    .log-table thead { background: linear-gradient(135deg, #f4c430, #e0b400); }
    .log-table th { color: #2b2b2b; font-weight: 700; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px; padding: 8px 10px; text-align: left; }
    .log-table td { padding: 8px 10px; font-size: 0.8rem; border-bottom: 1px solid #f0f0f0; vertical-align: top; }
    .log-table tbody tr:hover { background: #fffef5; }
    .log-table tbody tr:last-child td { border-bottom: none; }

    /* BADGES */
    .badge { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 0.7rem; font-weight: 600; }
    .b-create { background: #d4edda; color: #155724; }
    .b-edit, .b-update { background: #fff3cd; color: #856404; }
    .b-delete { background: #f8d7da; color: #721c24; }
    .b-approve { background: #cce5ff; color: #004085; }
    .b-reject { background: #f8d7da; color: #721c24; }
    .b-logout { background: #e2e3e5; color: #383d41; }
    .b-default { background: #fff7cc; color: #856404; }

    .module-tag { background: #f0f0f0; color: #333; padding: 2px 6px; border-radius: 6px; font-size: 0.7rem; }

    .details-text { color: #666; font-size: 0.78rem; max-width: 400px; word-break: break-word; line-height: 1.4; }

    .empty-state { text-align: center; padding: 30px; color: #aaa; }
    .empty-state i { font-size: 2rem; margin-bottom: 6px; display: block; }

    /* PAGINATION */
    .pagination-wrapper { margin-top: 24px; display: flex; justify-content: space-between; align-items: center; background: #fff; padding: 12px 20px; border-radius: 12px; border: 1px solid #f0f0f0; }
    .pagination-info { font-size: 0.85rem; color: #666; }
    
    .pagination { display: flex; gap: 6px; list-style: none; padding: 0; margin: 0; }
    .page-item { }
    .page-link { 
        display: inline-block; padding: 6px 1px; min-width: 32px; text-align: center; border-radius: 8px; 
        border: 1px solid #ddd; color: #555; text-decoration: none; font-size: 0.85rem; font-weight: 600; transition: all 0.2s;
    }
    .page-link:hover { background: #f4c430; border-color: #f4c430; color: #2b2b2b; }
    .page-item.active .page-link { background: #f4c430; border-color: #f4c430; color: #2b2b2b; }
    .page-item.disabled .page-link { background: #f9f9f9; color: #ccc; border-color: #eee; cursor: not-allowed; pointer-events: none; }
    
    .page-link-icon { padding: 6px 12px; }
</style>

<div class="audit-wrapper">

    <!-- HEADER -->
    <div class="page-header">
        <h2><i class="bi bi-shield-check"></i> Audit Log</h2>
        <p>All system activity is shown below. Use filters to narrow results.</p>
    </div>

    <!-- FILTER BAR -->
    <form method="get" asp-controller="SuperAdmin" asp-action="AuditLog">
        <div class="filter-bar">
            <div class="filter-group">
                <label>Role</label>
                <select name="roleFilter">
                    <option value="">All</option>
                    @foreach (var r in Model.Roles)
                    {
                        if (Model.Role == r)
                        { <option value="@r" selected>@r</option> }
                        else
                        { <option value="@r">@r</option> }
                    }
                </select>
            </div>
            <div class="filter-group">
                <label>Action</label>
                <select name="actionFilter">
                    <option value="">All</option>
                    @foreach (var a in Model.Actions)
                    {
                        if (Model.Action == a)
                        { <option value="@a" selected>@a</option> }
                        else
                        { <option value="@a">@a</option> }
                    }
                </select>
            </div>
            <div style="display:flex; gap:6px; align-self:end;">
                <button type="submit" class="btn-apply"><i class="bi bi-funnel"></i> Filter</button>
                <a asp-controller="SuperAdmin" asp-action="AuditLog" class="btn-reset"><i class="bi bi-arrow-counterclockwise"></i></a>
            </div>
        </div>
    </form>

    <!-- RESULT COUNT -->
    <div class="result-count">
        Showing <strong>@Model.Logs.Count</strong> of <strong>@Model.TotalRecords</strong> record(s)
    </div>

    <!-- AJAX CONTAINER -->
    <div id="ajax-pagination-container">
        @await Html.PartialAsync("_AuditLogTable", Model)
    </div>
</div>
</div>
