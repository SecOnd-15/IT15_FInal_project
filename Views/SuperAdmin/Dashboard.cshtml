@model Latog_Final_project.Models.DashboardViewModel

@{
    ViewData["Title"] = "System Control Center";
    // Ensure Model is not null to prevent rendering crashes
    if (Model == null) {
        <div class="container py-5 text-center">
            <h3>Configuration Pending</h3>
            <p>Please ensure your database is seeded. Log in as SuperAdmin to see details.</p>
        </div>
        return;
    }
}

<style>
    /* Dashboard-specific tweaks only */
    .metric-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2.5rem;
    }

    .metric-label { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; color: var(--premium-text-muted); letter-spacing: 0.05em; margin-bottom: 0.75rem; }
    .metric-value { font-size: 2.25rem; font-weight: 800; color: var(--premium-primary); line-height: 1; text-align: right; }
    .metric-trend { font-size: 0.8rem; font-weight: 600; margin-top: 0.75rem; display: flex; align-items: center; gap: 4px; }

    .panel-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
    .panel-title { font-weight: 800; font-size: 1.2rem; color: var(--premium-primary); letter-spacing: -0.02em; }

    .badge-premium {
        padding: 0.35rem 0.85rem;
        border-radius: 8px;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.025em;
    }
</style>


<div class="container-fluid px-4 py-3">
    <div class="d-flex justify-content-between align-items-center mb-4 pt-2">
        <div>
            <h1 class="fw-800 mb-0" style="letter-spacing: -0.04em;">Command Center</h1>
            <p class="text-muted fw-500 mb-0"><i class="bi bi-cpu me-1"></i> Global System Intelligence Dashboard</p>
        </div>
        <div class="d-flex align-items-center gap-3">
            <!-- Filter Form -->
            <form method="get" asp-action="Dashboard" class="d-flex align-items-center gap-2">
                <select name="month" class="form-select form-select-sm rounded-pill px-3 fw-bold border-0 shadow-sm" style="width: auto; background-color: #ffffff; height: 42px;" onchange="this.form.submit()">
                    <option value="">All Months</option>
                    @for (int i = 1; i <= 12; i++)
                    {
                        <option value="@i" selected="@(Model.FilterMonth == i)">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)</option>
                    }
                </select>

                <select name="year" class="form-select form-select-sm rounded-pill px-3 fw-bold border-0 shadow-sm" style="width: auto; background-color: #ffffff; height: 42px;" onchange="this.form.submit()">
                    <option value="">All Years</option>
                    @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--)
                    {
                        <option value="@y" selected="@(Model.FilterYear == y)">@y</option>
                    }
                </select>
                <button type="submit" class="btn btn-sm rounded-pill px-4 fw-bold shadow-sm" style="background-color: #facc15; color: #0f172a; height: 42px; border: none;">Filter</button>
            </form>

            <div class="vr mx-1" style="height: 30px; opacity: 0.1;"></div>

            <a href="@Url.Action("AuditLog", "SuperAdmin")" class="btn btn-dark rounded-pill px-4 fw-bold shadow-sm d-flex align-items-center justify-content-center" style="background-color: #1e293b; height: 42px; border: none;">
                <i class="bi bi-terminal me-2"></i> Logs
            </a>
            <button class="btn btn-light rounded-circle d-flex align-items-center justify-content-center shadow-sm border-0" style="width: 42px; height: 42px; background-color: white;" onclick="location.reload()" title="Refresh Dashboard">
                <i class="bi bi-arrow-clockwise fs-5"></i>
            </button>
        </div>
    </div>

    <!-- KPIs -->
    <div class="metric-grid">
        <div class="p-card border-0 shadow-sm">
            <div class="metric-label">Global User Base</div>
            <div class="metric-value">@Model.TotalUsers</div>
            <div class="metric-trend" style="color: #10b981;"><i class="bi bi-activity"></i> Active System</div>
        </div>
        <div class="p-card border-0 shadow-sm">
            <div class="metric-label">Active Barangays</div>
            <div class="metric-value">@Model.TotalBranches</div>
            <div class="metric-trend" style="color: #6366f1;"><i class="bi bi-diagram-3"></i> Unified Network</div>
        </div>
        <div class="p-card border-0 shadow-sm">
            <div class="metric-label">Total Audit Events</div>
            <div class="metric-value">@Model.TotalTransactions</div>
            <div class="metric-trend" style="color: #f59e0b;"><i class="bi bi-shield-check"></i> Integrity Verified</div>
        </div>
        <div class="p-card border-0 shadow-sm">
            <div class="metric-label">System Health</div>
            <div class="metric-value">99.9%</div>
            <div class="metric-trend" style="color: #10b981;"><i class="bi bi-check2-circle"></i> Operational</div>
        </div>
    </div>

    <!-- Main Analytics Row -->
    <div class="row g-4 mb-4">
        <!-- Global Activity Wave -->
        <div class="col-lg-8">
            <div class="p-card">
                <div class="panel-header">
                    <h2 class="panel-title">Global System Activity Wave</h2>
                    <div class="badge-premium bg-dark text-white">Last 30 Days</div>
                </div>
                <div style="height: 350px;">
                    <canvas id="globalActivityChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Role distribution -->
        <div class="col-lg-4">
            <div class="p-card">
                <div class="panel-header">
                    <h2 class="panel-title">User Privilege Core</h2>
                </div>
                <div style="height: 350px;">
                    <canvas id="roleDistributionChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Branch Comparison -->
        <div class="col-lg-12">
            <div class="p-card">
                <div class="panel-header">
                    <h2 class="panel-title">Barangay Activity Comparison</h2>
                </div>
                <div style="height: 450px;">
                    <canvas id="branchComparisonChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

    <script>
        // Shared Options
        const sharedOpts = {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, grid: { color: '#f1f5f9' }, border: { display: false } },
                x: { grid: { display: false }, border: { display: false } }
            }
        };

        // 1. Global Activity (Area)
        new Chart(document.getElementById('globalActivityChart'), {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.GlobalSystemActivity.Select(d => d.Label))),
                datasets: [{
                    data: @Html.Raw(Json.Serialize(Model.GlobalSystemActivity.Select(d => d.Value))),
                    borderColor: '#4f46e5',
                    backgroundColor: (ctx) => {
                        const bg = ctx.chart.ctx.createLinearGradient(0,0,0,350);
                        bg.addColorStop(0, 'rgba(79, 70, 229, 0.2)');
                        bg.addColorStop(1, 'rgba(79, 70, 229, 0)');
                        return bg;
                    },
                    fill: true,
                    tension: 0.5,
                    borderWidth: 4,
                    pointRadius: 0,
                    pointHoverRadius: 6
                }]
            },
            options: sharedOpts
        });

        // 2. Role Distribution (Doughnut)
        new Chart(document.getElementById('roleDistributionChart'), {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.UserRoleDistribution.Select(d => d.Label))),
                datasets: [{
                    data: @Html.Raw(Json.Serialize(Model.UserRoleDistribution.Select(d => d.Value))),
                    backgroundColor: ['#3b82f6', '#10b981', '#f59e0b', '#ef4444', '#6366f1'],
                    borderWidth: 8,
                    borderColor: '#fff',
                    hoverOffset: 20
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '75%',
                plugins: {
                    legend: {
                        display: true,
                        position: 'bottom',
                        labels: { padding: 30, usePointStyle: true, font: { weight: '800', family: 'Inter', size: 12 } }
                    }
                }
            }
        });

        
        new Chart(document.getElementById('branchComparisonChart'), {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.BranchActivity.Select(d => d.Label))),
                datasets: [{
                    data: @Html.Raw(Json.Serialize(Model.BranchActivity.Select(d => d.Value))),
                    backgroundColor: '#1e293b',
                    borderRadius: 10,
                    barThickness: 30
                }]
            },
            options: {
                indexAxis: 'y',
                ...sharedOpts
            }
        });
    </script>
}
