@model List<Latog_Final_project.Models.Branch>

@{
    ViewData["Title"] = "Barangay Management";
}

<style>
    /* Branches-specific hover effect */
    .branch-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid var(--premium-border);
    }
    .branch-card:hover {
        transform: translateY(-8px);
        border-color: #facc15;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    }
    .bg-soft-gold { background: rgba(250, 204, 21, 0.1); color: #d97706; }
    .bg-soft-gray { background: #f8fafc; }
</style>

<div class="container-fluid px-4 py-3">
    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4 pt-2">
        <div>
            <h1 class="fw-800 mb-0" style="letter-spacing: -0.04em;">Barangay Directory</h1>
            <p class="text-muted fw-500 mb-0"><i class="bi bi-geo-alt me-1 text-primary"></i> Active System Network Nodes</p>
        </div>
        <a asp-action="AddBranch" class="btn btn-warning rounded-pill px-4 fw-800 shadow-sm text-dark d-flex align-items-center text-decoration-none" style="background-color: #facc15; border: none; height: 42px;">
            <i class="bi bi-plus-circle me-2"></i> Add New Barangay
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-4 mb-4">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        </div>
    }

    <div class="row g-4">
        @foreach (var branch in Model)
        {
            <div class="col-xl-4 col-md-6">
                <div class="p-card branch-card h-100 d-flex flex-column" style="border-top: 5px solid #facc15; border-radius: 18px; @(!branch.IsActive ? "opacity: 0.7; filter: grayscale(0.5);" : "")">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div class="p-3 rounded-4 bg-soft-gold d-flex align-items-center justify-content-center" style="width: 52px; height: 52px;">
                            <i class="bi bi-building" style="font-size: 1.5rem;"></i>
                        </div>
                        @if (branch.IsActive)
                        {
                            <span class="p-badge p-badge-success text-uppercase">Active</span>
                        }
                        else
                        {
                            <span class="p-badge p-badge-danger text-uppercase">Inactive</span>
                        }
                    </div>

                    <h4 class="fw-800 mb-1 text-dark">@branch.BranchName</h4>
                    <p class="text-muted small fw-600">Official Barangay Office</p>

                    <div class="my-4 p-3 rounded-4 bg-soft-gray">
                        <div class="text-muted small d-flex align-items-center mb-1">
                            <i class="bi bi-geo-alt me-2 text-primary"></i> @(string.IsNullOrEmpty(branch.Location) ? branch.BranchName : branch.Location)
                        </div>
                        <div class="text-muted small d-flex align-items-center">
                            <i class="bi bi-telephone me-2 text-primary"></i> @(string.IsNullOrEmpty(branch.ContactNumber) ? "No Contact" : branch.ContactNumber)
                        </div>
                    </div>

                    <div class="mb-4 flex-grow-1">
                        <label class="fw-800 text-dark small d-flex align-items-center mb-3 text-uppercase letter-spacing-05">
                            <i class="bi bi-person-badge me-2 text-warning"></i> Authorized Staff
                        </label>
                        <div class="staff-list px-1" style="max-height: 120px; overflow-y: auto;">
                            @{
                                var branchUsers = (Dictionary<int, List<Latog_Final_project.Models.ApplicationUser>>)ViewBag.BranchUsers;
                                if (branchUsers.ContainsKey(branch.Id) && branchUsers[branch.Id].Any())
                                {
                                    foreach (var bUser in branchUsers[branch.Id])
                                    {
                                        <div class="d-flex align-items-center mb-3">
                                            <div class="rounded-circle bg-warning me-2" style="width: 8px; height: 8px;"></div>
                                            <div class="small fw-700 text-dark truncate" title="@bUser.Email">
                                                @(string.IsNullOrEmpty(bUser.FullName) ? bUser.Email : bUser.FullName)
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="text-muted italic small py-2">No active staff found in this node</div>
                                }
                            }
                        </div>
                    </div>

                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex gap-2">
                            <a asp-action="EditBranch" asp-route-id="@branch.Id" class="btn btn-outline-dark w-100 fw-800 rounded-pill py-2 border-2">
                                <i class="bi bi-pencil-square me-1"></i> Edit
                            </a>
                            <form asp-action="ToggleBranchStatus" method="post" class="w-100 m-0 p-0 toggle-branch-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@branch.Id" />
                                @if (branch.IsActive)
                                {
                                    <button type="button" class="btn btn-outline-warning w-100 fw-800 rounded-pill py-2 border-2 toggle-branch-btn" data-action="deactivate" data-name="@branch.BranchName">
                                        <i class="bi bi-pause-circle me-1"></i> Deactivate
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-outline-success w-100 fw-800 rounded-pill py-2 border-2 toggle-branch-btn" data-action="activate" data-name="@branch.BranchName">
                                        <i class="bi bi-play-circle me-1"></i> Activate
                                    </button>
                                }
                            </form>
                        </div>
                        <a asp-action="Index" asp-route-branchId="@branch.Id" class="btn btn-warning w-100 fw-800 rounded-3 py-2 shadow-sm text-dark">
                            <i class="bi bi-people-fill me-2"></i> Users
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.toggle-branch-btn').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var action = btn.getAttribute('data-action');
                    var name = btn.getAttribute('data-name');
                    var isDeactivate = action === 'deactivate';

                    Swal.fire({
                        title: isDeactivate ? 'Deactivate Barangay?' : 'Activate Barangay?',
                        text: 'Are you sure you want to ' + action + ' ' + name + '?',
                        icon: isDeactivate ? 'warning' : 'question',
                        showCancelButton: true,
                        confirmButtonColor: isDeactivate ? '#f59e0b' : '#10b981',
                        cancelButtonColor: '#64748b',
                        confirmButtonText: isDeactivate ? 'Yes, Deactivate' : 'Yes, Activate',
                        cancelButtonText: 'Cancel',
                        reverseButtons: true
                    }).then(function (result) {
                        if (result.isConfirmed) {
                            btn.closest('form').submit();
                        }
                    });
                });
            });
        });
    </script>
}
